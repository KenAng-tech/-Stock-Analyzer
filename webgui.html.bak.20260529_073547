    container.innerHTML = state.positions.map(p => {
        const pnlClass = p.unrealized_pnl >= 0 ? 'positive' : 'negative';
        const pnlSign = p.unrealized_pnl >= 0 ? '+' : '';
        return `
            <div class="position-card">
                <div class="position-header">
                    <div>
                        <div class="position-symbol">${p.symbol}</div>
                        <div class="position-name">${p.name || ''}</div>
                    </div>
                    <span class="position-side">${p.side || 'LONG'}</span>
                </div>
                <div class="position-details">
                    <div>
                        <div class="position-detail-label">Quantity</div>
                        <div class="position-detail-value">${p.quantity || '--'}</div>
                    </div>
                    <div>
                        <div class="position-detail-label">Leverage</div>
                        <div class="position-detail-value">${p.leverage || '1.0'}x</div>
                    </div>
                    <div>
                        <div class="position-detail-label">Entry Price</div>
                        <div class="position-detail-value">$${formatNumber(p.entry_price)}</div>
                    </div>
                    <div>
                        <div class="position-detail-label">Current Price</div>
                        <div class="position-detail-value">$${formatNumber(p.current_price)}</div>
                    </div>
                </div>
                <div class="position-pnl">
                    <span class="position-detail-label">Unrealized P&L</span>
                    <span class="pnl-value ${pnlClass}">${pnlSign}$${formatNumber(Math.abs(p.unrealized_pnl || 0), 2)}</span>
                </div>
            </div>
        `;
    }).join('');
}

function renderAnalysisStocks() {
    const container = document.getElementById('analysisStocksList');

    if (state.stocks.length === 0) {
        container.innerHTML = '<div class="empty-state"><div class="empty-state-icon">&#9888;</div><div class="empty-state-text">No stocks configured</div></div>';
        return;
    }

    container.innerHTML = state.stocks.map(s => `
        <div class="stock-item">
            <div class="stock-info">
                <span class="stock-code">${s.code}</span>
                <span class="stock-name">${s.name || ''}</span>
                <span class="stock-sector">${s.sector || ''}</span>
            </div>
            <div class="stock-price">
                <div class="price-value" style="color: var(--text-primary);">$--.--</div>
                <div class="price-change up">+0.00%</div>
            </div>
        </div>
    `).join('');
}

// ============================================================================
// Charts
// ============================================================================
function renderAll() {
    renderDashboardQuickSummary();
    renderDashboardPerformance();
    renderDashboardSignals();
    renderDashboardPositions();
    renderAnalysisPerformance();
    renderAnalysisSignals();
    renderAnalysisPositions();
    renderAnalysisStocks();

    // Render charts for current page
    if (state.currentPage === 'dashboard') {
        renderDashboardCharts();
    } else {
        renderAnalysisCharts();
    }
}

function updateLastUpdated() {
    const el = document.getElementById('lastUpdated');
    const now = new Date();
    el.textContent = 'Updated: ' + now.toLocaleTimeString('zh-CN');
}

function renderDashboardCharts() {
    renderDashboardSignalChart();
    renderDashboardPerformanceChart();
}

function renderAnalysisCharts() {
    renderAnalysisSignalChart();
    renderAnalysisPerformanceChart();
}

function renderDashboardSignalChart() {
    const ctx = document.getElementById('signalChart').getContext('2d');
    const counts = { BUY: 0, SELL: 0, HOLD: 0 };
    state.signals.forEach(s => { if (counts[s.direction] !== undefined) counts[s.direction]++; });

    if (state.charts.signal) state.charts.signal.destroy();

    state.charts.signal = new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['BUY', 'SELL', 'HOLD'],
            datasets: [{
                data: [counts.BUY, counts.SELL, counts.HOLD],
                backgroundColor: ['#3fb950', '#f85149', '#d29922'],
                borderWidth: 0,
                hoverOffset: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { color: '#8b949e', padding: 16, font: { size: 12 } }
                }
            }
        }
    });
}

function renderAnalysisSignalChart() {
    const ctx = document.getElementById('analysisSignalChart').getContext('2d');
    const counts = { BUY: 0, SELL: 0, HOLD: 0 };
    state.signals.forEach(s => { if (counts[s.direction] !== undefined) counts[s.direction]++; });

    if (state.charts.analysisSignal) state.charts.analysisSignal.destroy();

    state.charts.analysisSignal = new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['BUY', 'SELL', 'HOLD'],
            datasets: [{
                data: [counts.BUY, counts.SELL, counts.HOLD],
                backgroundColor: ['#3fb950', '#f85149', '#d29922'],
                borderWidth: 0,
                hoverOffset: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { color: '#8b949e', padding: 16, font: { size: 12 } }
                }
            }
        }
    });
}

function renderDashboardPerformanceChart() {
    const ctx = document.getElementById('performanceChart').getContext('2d');

    const days = 30;
    const labels = [];
    const data = [];
    let cumulative = 0;
    for (let i = 0; i < days; i++) {
        labels.push('Day ' + (i + 1));
        cumulative += (Math.random() - 0.4) * 2;
        data.push(cumulative);
    }

    if (state.charts.performance) state.charts.performance.destroy();

    state.charts.performance = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Cumulative Return',
                data: data,
                borderColor: '#58a6ff',
                backgroundColor: 'rgba(88, 166, 255, 0.1)',
                fill: true,
                tension: 0.4,
                pointRadius: 0,
                pointHoverRadius: 4,
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                x: {
                    grid: { color: 'rgba(48, 54, 61, 0.5)' },
                    ticks: { color: '#8b949e', font: { size: 10 }, maxTicksLimit: 10 }
                },
                y: {
                    grid: { color: 'rgba(48, 54, 61, 0.5)' },
                    ticks: { color: '#8b949e', font: { size: 10 }, callback: v => v.toFixed(1) + '%' }
                }
            },
            plugins: {
                legend: { display: false }
            }
        }
    });
}

function renderAnalysisPerformanceChart() {
    const ctx = document.getElementById('analysisPerformanceChart').getContext('2d');

    const days = 30;
    const labels = [];
    const data = [];
    let cumulative = 0;
    for (let i = 0; i < days; i++) {
        labels.push('Day ' + (i + 1));
        cumulative += (Math.random() - 0.4) * 2;
        data.push(cumulative);
    }

    if (state.charts.analysisPerformance) state.charts.analysisPerformance.destroy();

    state.charts.analysisPerformance = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Cumulative Return',
                data: data,
                borderColor: '#58a6ff',
                backgroundColor: 'rgba(88, 166, 255, 0.1)',
                fill: true,
                tension: 0.4,
                pointRadius: 0,
                pointHoverRadius: 4,
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                x: {
                    grid: { color: 'rgba(48, 54, 61, 0.5)' },
                    ticks: { color: '#8b949e', font: { size: 10 }, maxTicksLimit: 10 }
                },
                y: {
                    grid: { color: 'rgba(48, 54, 61, 0.5)' },
                    ticks: { color: '#8b949e', font: { size: 10 }, callback: v => v.toFixed(1) + '%' }
                }
            },
            plugins: {
                legend: { display: false }
            }
        }
    });
}

// ============================================================================
// UI Actions
// ============================================================================
function showLoading(show) {
    document.getElementById('loadingOverlay').className = show ? 'loading-overlay active' : 'loading-overlay';
    document.getElementById('refreshBtn').className = show ? 'btn btn-primary btn-loading' : 'btn btn-primary';
}

function showNotification(message, type = 'success') {
    const el = document.getElementById('notification');
    el.textContent = message;
    el.className = 'notification ' + type + ' show';
    setTimeout(() => { el.className = 'notification ' + type; }, 3000);
}

async function refreshAll() {
    showLoading(true);
    await apiPost('/api/quant/refresh');
    await fetchAll();
    showNotification('Data refreshed');
}

function startAutoRefresh() {
    if (state.refreshTimer) clearInterval(state.refreshTimer);
    state.refreshTimer = setInterval(() => {
        if (!isTradingHours()) return;
        fetchAll();
    }, getRefreshInterval());
}

// ============================================================================
// Initialization
// ============================================================================
async function init() {
    const path = window.location.pathname;
    if (path.startsWith('/webgui')) {
        CONFIG.API_BASE = '';
    } else {
        CONFIG.API_BASE = '';
    }

    await fetchHealth();
    await fetchAll();
    startAutoRefresh();

    setInterval(fetchHealth, 60000);
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
} else {
    init();
}
</script>

