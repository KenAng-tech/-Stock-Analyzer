    document.getElementById('analysisSignalCount').textContent = '(' + state.signals.length + ')';

    if (state.signals.length === 0) {
        tbody.innerHTML = '<tr><td colspan="9"><div class="empty-state"><div class="empty-state-icon">&#9888;</div><div class="empty-state-text">No signals generated</div></div></td></tr>';
