    const container = document.getElementById('analysisPositionsGrid');
    document.getElementById('analysisPositionCount').textContent = '(' + state.positions.length + ')';

    if (state.positions.length === 0) {
        container.innerHTML = '<div class="empty-state" style="grid-column: 1/-1;"><div class="empty-state-icon">&#9888;</div><div class="empty-state-text">No open positions</div></div>';
