</footer>

<script>
// ============================================================================
// Configuration
// ============================================================================
const CONFIG = {
    API_BASE: '',
    REFRESH_INTERVAL: 15000,  // 15 seconds
    TRADING_HOURS: [
        { start: { h: 9, m: 30 }, end: { h: 11, m: 30 } },
        { start: { h: 13, m: 0 }, end: { h: 15, m: 0 } }
    ]
};

// ============================================================================
// State
// ============================================================================
let state = {
    signals: [],
    positions: [],
    performance: null,
    stocks: [],
    charts: {},
    refreshTimer: null,
    currentPage: 'dashboard'
};

// ============================================================================
// Utility Functions
// ============================================================================
function formatTime(timestamp) {
    if (!timestamp) return '--';
    const d = new Date(timestamp);
    return d.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
}

function formatDate(timestamp) {
    if (!timestamp) return '--';
    const d = new Date(timestamp);
    return d.toLocaleDateString('zh-CN');
}

function formatNumber(n, decimals = 2) {
    if (n === null || n === undefined) return '--';
    return Number(n).toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
}

function formatPnL(pnl) {
    if (pnl === null || pnl === undefined) return '--';
    const sign = pnl >= 0 ? '+' : '';
    return sign + '$' + formatNumber(Math.abs(pnl), 2);
}

function getConfidenceClass(c) {
    if (c >= 0.7) return 'high';
    if (c >= 0.4) return 'medium';
    return 'low';
}

function isTradingHours() {
    const now = new Date();
    const h = now.getHours();
    const m = now.getMinutes();
    const time = h * 60 + m;
    for (const period of CONFIG.TRADING_HOURS) {
        const start = period.start.h * 60 + period.start.m;
        const end = period.end.h * 60 + period.end.m;
        if (time >= start && time <= end) return true;
    }
    return false;
}

function getRefreshInterval() {
    return isTradingHours() ? 10000 : 30000;
}

// ============================================================================
// Page Switching
// ============================================================================
function switchPage(page) {
    state.currentPage = page;

    // Update tab styles
    document.querySelectorAll('.page-tab').forEach(tab => {
        tab.classList.toggle('active', tab.dataset.page === page);
    });

    // Update page visibility
    document.querySelectorAll('.page-section').forEach(section => {
        section.classList.toggle('active', section.id === page + 'Page');
    });

    // Refresh charts for the active page
    if (page === 'dashboard') {
        renderDashboardCharts();
    } else {
        renderAnalysisCharts();
    }
}

// ============================================================================
// API Functions
// ============================================================================
async function apiGet(endpoint) {
    try {
        const resp = await fetch(CONFIG.API_BASE + endpoint);
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        return await resp.json();
    } catch (e) {
        console.warn('API GET failed:', endpoint, e.message);
        return null;
    }
}

async function apiPost(endpoint, body = {}) {
    try {
        const resp = await fetch(CONFIG.API_BASE + endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        return await resp.json();
    } catch (e) {
        console.warn('API POST failed:', endpoint, e.message);
        return null;
    }
}

async function fetchHealth() {
    const data = await apiGet('/api/health');
    if (data) {
        document.getElementById('connectionStatus').className = 'status-badge online';
        document.getElementById('connectionStatus').querySelector('span:last-child').textContent = 'Connected';
        document.getElementById('serverInfo').textContent = 'Server: v' + (data.version || '1.0.0') + ' | Port: ' + (window.location.port || '5002');
    } else {
        document.getElementById('connectionStatus').className = 'status-badge offline';
        document.getElementById('connectionStatus').querySelector('span:last-child').textContent = 'Disconnected';
    }
    return data;
}

async function fetchAll() {
    showLoading(true);
    const [signalsData, positionsData, performanceData, stocksData] = await Promise.all([
        apiGet('/api/quant/signals'),
        apiGet('/api/quant/positions'),
        apiGet('/api/quant/performance'),
        apiGet('/api/quant/stocks')
    ]);

    state.signals = signalsData || [];
    state.positions = positionsData || [];
    state.performance = performanceData || null;
    state.stocks = stocksData || [];

    renderAll();
    updateLastUpdated();
    showLoading(false);
}

// ============================================================================
// Dashboard Rendering (Simplified)
// ============================================================================
function renderDashboardQuickSummary() {
    const container = document.getElementById('dashboardQuickSummary');
    const buyCount = state.signals.filter(s => s.direction === 'BUY').length;
    const sellCount = state.signals.filter(s => s.direction === 'SELL').length;
    const totalPnL = state.positions.reduce((sum, p) => sum + (p.unrealized_pnl || 0), 0);

    container.innerHTML = `
        <div class="quick-item">
            <div class="quick-item-label">Active Signals</div>
            <div class="quick-item-value">${state.signals.length}</div>
            <div class="quick-item-sub">${buyCount} BUY / ${sellCount} SELL</div>
        </div>
        <div class="quick-item">
            <div class="quick-item-label">Open Positions</div>
            <div class="quick-item-value">${state.positions.length}</div>
            <div class="quick-item-sub">${state.positions.filter(p => p.side === 'LONG').length} LONG</div>
        </div>
        <div class="quick-item">
            <div class="quick-item-label">Total P&L</div>
            <div class="quick-item-value ${totalPnL >= 0 ? 'positive' : 'negative'}">${formatPnL(totalPnL)}</div>
            <div class="quick-item-sub">Unrealized</div>
        </div>
        <div class="quick-item">
            <div class="quick-item-label">Trading Status</div>
            <div class="quick-item-value">${isTradingHours() ? 'Active' : 'Closed'}</div>
            <div class="quick-item-sub">${isTradingHours() ? 'Market Open' : 'Next Open: 9:30'}</div>
        </div>
    `;
}

function renderDashboardPerformance() {
    const container = document.getElementById('performanceStats');
    if (!state.performance) return;
    const p = state.performance;
    const pnlClass = p.total_return >= 0 ? 'positive' : 'negative';

    const stats = [
        { label: 'Total Return', value: (p.total_return * 100).toFixed(2) + '%', cls: pnlClass },
        { label: 'Win Rate', value: (p.win_rate * 100).toFixed(1) + '%', cls: 'positive' },
        { label: 'Total Trades', value: p.total_trades?.toString() || '--', cls: 'neutral' },
        { label: 'Start Date', value: p.start_date || '--', cls: 'neutral' }
    ];

    container.innerHTML = stats.map(s => `
        <div class="stat-card">
            <div class="stat-label">${s.label}</div>
            <div class="stat-value ${s.cls}">${s.value}</div>
        </div>
    `).join('');
}

function renderDashboardSignals() {
    const tbody = document.getElementById('dashboardSignalsBody');
    document.getElementById('signalCount').textContent = '(' + state.signals.length + ')';

    if (state.signals.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5"><div class="empty-state"><div class="empty-state-icon">&#9888;</div><div class="empty-state-text">No signals generated</div></div></td></tr>';
        return;
    }

    // Show only recent 10 signals in dashboard
    const recentSignals = state.signals.slice(0, 10);

    tbody.innerHTML = recentSignals.map(s => {
        const confClass = getConfidenceClass(s.confidence);
        const time = s.timestamp ? formatTime(s.timestamp) : '--';
        return `
            <tr>
                <td><strong>${s.symbol}</strong></td>
                <td><span class="signal-direction ${s.direction}">${s.direction}</span></td>
                <td>
                    <span class="confidence-bar"><span class="confidence-fill ${confClass}" style="width: ${s.confidence * 100}%"></span></span>
                    ${(s.confidence * 100).toFixed(0)}%
                </td>
                <td><span class="strength-badge ${s.strength?.toLowerCase()}">${s.strength || '--'}</span></td>
                <td style="color: var(--text-secondary); font-size: 12px;">${time}</td>
            </tr>
        `;
    }).join('');
}

function renderDashboardPositions() {
    const container = document.getElementById('dashboardPositionsGrid');
    document.getElementById('positionCount').textContent = '(' + state.positions.length + ')';

    if (state.positions.length === 0) {
        container.innerHTML = '<div class="empty-state" style="grid-column: 1/-1;"><div class="empty-state-icon">&#9888;</div><div class="empty-state-text">No open positions</div></div>';
        return;
    }

    container.innerHTML = state.positions.map(p => {
        const pnlClass = p.unrealized_pnl >= 0 ? 'positive' : 'negative';
        const pnlSign = p.unrealized_pnl >= 0 ? '+' : '';
        return `
            <div class="position-card">
                <div class="position-header">
                    <div>
                        <div class="position-symbol">${p.symbol}</div>
                        <div class="position-name">${p.name || ''}</div>
                    </div>
                    <span class="position-side">${p.side || 'LONG'}</span>
                </div>
                <div class="position-details">
                    <div>
                        <div class="position-detail-label">Quantity</div>
                        <div class="position-detail-value">${p.quantity || '--'}</div>
                    </div>
                    <div>
                        <div class="position-detail-label">Leverage</div>
                        <div class="position-detail-value">${p.leverage || '1.0'}x</div>
                    </div>
                    <div>
                        <div class="position-detail-label">Entry Price</div>
                        <div class="position-detail-value">$${formatNumber(p.entry_price)}</div>
                    </div>
                    <div>
                        <div class="position-detail-label">Current Price</div>
                        <div class="position-detail-value">$${formatNumber(p.current_price)}</div>
                    </div>
                </div>
                <div class="position-pnl">
                    <span class="position-detail-label">Unrealized P&L</span>
                    <span class="pnl-value ${pnlClass}">${pnlSign}$${formatNumber(Math.abs(p.unrealized_pnl || 0), 2)}</span>
                </div>
            </div>
        `;
    }).join('');
}

// ============================================================================
// Analysis Page Rendering (Detailed)
// ============================================================================
function renderAnalysisPerformance() {
    const container = document.getElementById('analysisPerformanceStats');
    if (!state.performance) return;
    const p = state.performance;
    const pnlClass = p.total_return >= 0 ? 'positive' : 'negative';

    const stats = [
        { label: 'Total Return', value: (p.total_return * 100).toFixed(2) + '%', cls: pnlClass },
        { label: 'Win Rate', value: (p.win_rate * 100).toFixed(1) + '%', cls: 'positive' },
        { label: 'Total Trades', value: p.total_trades?.toString() || '--', cls: 'neutral' },
        { label: 'Start Date', value: p.start_date || '--', cls: 'neutral' }
    ];

    container.innerHTML = stats.map(s => `
        <div class="stat-card">
