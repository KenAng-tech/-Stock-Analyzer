    }

    tbody.innerHTML = state.signals.map(s => {
        const confClass = getConfidenceClass(s.confidence);
        const time = s.timestamp ? formatTime(s.timestamp) : '--';
        return `
            <tr>
                <td><strong>${s.symbol}</strong></td>
                <td>${s.name || ''}</td>
                <td><span class="signal-sector">${s.sector || ''}</span></td>
                <td><span class="signal-direction ${s.direction}">${s.direction}</span></td>
                <td class="signal-price">${s.price || '--'}</td>
                <td><span class="signal-change ${s.change >= 0 ? 'positive' : 'negative'}">${s.change != null ? (s.change >= 0 ? '+' : '') + s.change.toFixed(2) + '%' : '--'}</span></td>
                <td>
                    <span class="confidence-bar"><span class="confidence-fill ${confClass}" style="width: ${s.confidence * 100}%"></span></span>
                    ${(s.confidence * 100).toFixed(0)}%
                </td>
                <td style="color: var(--text-secondary); font-size: 12px;">${s.source || '--'}</td>
                <td style="color: var(--text-secondary); font-size: 12px;">${time}</td>
